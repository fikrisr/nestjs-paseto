{
  "name": "@fikrisr/nestjs-paseto",
  "version": "1.0.1",
  "description": "Platform-Agnostic Security Tokens (PASETO) utility module for NestJS using native node crypto",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "Fikri SR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fikrisr/nestjs-paseto.git"
  },
  "bugs": {
    "url": "https://github.com/fikrisr/nestjs-paseto/issues"
  },
  "homepage": "https://github.com/fikrisr/nestjs-paseto#readme",
  "keywords": [
    "nestjs",
    "paseto",
    "token",
    "authentication",
    "crypto",
    "chacha20-poly1305",
    "v4.local"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.1.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.0.0"
  }
}